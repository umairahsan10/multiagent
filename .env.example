# ============================================================
# LLM PROVIDERS (get all three; the system uses heterogeneous models)
# ============================================================

# Google Gemini — used by Methodology + Ethics reviewers
# Get at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenRouter — used by Novelty reviewer (routes to DeepSeek V3 on free tier)
# Free: 20 req/min, 50 req/day without credits, 1000/day with $10 credit
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq (Llama 3.3 70B) — used by Devil's Advocate + Editor
# Get at: https://console.groq.com/keys
GROQ_API_KEY=

# ============================================================
# EXTERNAL DATA APIS
# ============================================================

# OpenAlex — primary scholarly metadata source. NO KEY NEEDED.
# Just provide your email to join the "polite pool" (faster routing, 100k req/day).
# Docs: https://docs.openalex.org/how-to-use-the-api/api-overview
OPENALEX_EMAIL=

# Semantic Scholar — kept as optional fallback. Unauthenticated is 100 req / 5min.
# Skip unless you already have a key. Request at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ============================================================
# LOCAL PATHS
# ============================================================

# Where parsed papers + ChromaDB persist
DATA_DIR=./data
CHROMA_DIR=./data/chroma
PAPER_CACHE_DIR=./data/papers

# ============================================================
# RUNTIME CONFIG
# ============================================================

# Debate settings
MAX_DEBATE_ROUNDS=3
DISAGREEMENT_THRESHOLD=0.35

# Sandbox for stats-verifier (seconds)
SANDBOX_TIMEOUT=5

# Logging
LOG_LEVEL=INFO
